server {
  listen 443 ssl http2;
  server_name sms-verify.example.com;

  ssl_certificate /etc/letsencrypt/live/sms-verify.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/sms-verify.example.com/privkey.pem;

  client_max_body_size 16k;
  location = /v1/messages/send {
    proxy_pass http://127.0.0.1:8788;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto https;
    proxy_connect_timeout 5s;
    proxy_read_timeout 15s;
  }
  location = /healthz {
    proxy_pass http://127.0.0.1:8788;
  }
}