server {
    listen 443 ssl;
    server_name <voice-verification-hostname>;
    ssl_certificate /etc/letsencrypt/live/<voice-verification-hostname>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<voice-verification-hostname>/privkey.pem;
    client_max_body_size 16k;
    location = /v1/calls/start {
        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 5s;
        proxy_read_timeout 15s;
    }
    location = /health { proxy_pass http://127.0.0.1:8787; }
    location / { return 404; }
}