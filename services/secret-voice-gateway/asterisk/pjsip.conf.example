; A SIP/PSTN trunk is still required to reach real telephone numbers.
; Replace every placeholder with credentials from the selected carrier.
[carrier-registration]
type=registration
outbound_auth=carrier-auth
server_uri=sip:<carrier-host>
client_uri=sip:<account>@<carrier-host>
retry_interval=60
[carrier-auth]
type=auth
auth_type=userpass
username=<account>
password=<password>
[carrier]
type=aor
contact=sip:<carrier-host>
[carrier]
type=endpoint
transport=transport-udp
context=from-carrier
disallow=all
allow=ulaw,alaw
outbound_auth=carrier-auth
aors=carrier
from_user=<account>