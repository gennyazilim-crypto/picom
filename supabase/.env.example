# Supabase Edge Function secrets for local/staging setup.
# Copy to a local ignored file or set with `supabase secrets set`.
# Never expose these values through VITE_ variables or commit real values.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PICOM_ALLOWED_ORIGINS=
PICOM_V1_VOICE_SCREEN_ENABLED=false

# Optional health placeholders; do not include credentials.
PICOM_HEALTH_DATABASE_STATUS=ok_placeholder
PICOM_HEALTH_REDIS_STATUS=not_required
PICOM_HEALTH_STORAGE_STATUS=ok_placeholder
PICOM_HEALTH_REALTIME_STATUS=ok_placeholder
