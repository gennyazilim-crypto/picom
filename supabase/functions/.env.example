# Picom Supabase Edge Function local environment
# Copy to a local function-only .env file when using Supabase CLI.
# Do not commit real secrets.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key

# LiveKit server-side credentials for supabase/functions/livekit-token only.
# Never expose these as VITE_ variables or renderer/preload values.
LIVEKIT_URL=https://your-livekit-host.example
LIVEKIT_API_KEY=replace-with-local-livekit-api-key
LIVEKIT_API_SECRET=replace-with-local-livekit-api-secret

# Email placeholder provider for future Edge Function email intents.
# Keep real SMTP credentials out of git and set them only through Supabase secrets.
EMAIL_PROVIDER=log
SMTP_HOST_PLACEHOLDER=
SMTP_PORT_PLACEHOLDER=
SMTP_USER_PLACEHOLDER=
SMTP_PASS_PLACEHOLDER=
