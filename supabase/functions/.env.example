# Picom Supabase Edge Function local environment
# Copy to a local function-only .env file when using Supabase CLI.
# Do not commit real secrets.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
# Server/Edge Function only. Supabase normally injects this in deployed functions.
# Never rename with a VITE_ prefix or pass it to the Electron renderer.
SUPABASE_SERVICE_ROLE_KEY=

# LiveKit server-side credentials for supabase/functions/livekit-token only.
# Never expose these as VITE_ variables or renderer/preload values.
LIVEKIT_URL=https://your-livekit-host.example
LIVEKIT_API_KEY=replace-with-local-livekit-api-key
LIVEKIT_API_SECRET=replace-with-local-livekit-api-secret
PICOM_ALLOWED_ORIGINS=http://127.0.0.1:5173

# Internal account-deletion worker. Keep disabled unless operations/legal approve it.
ACCOUNT_DELETION_FINALIZATION_ENABLED=false
ACCOUNT_DELETION_WORKER_SECRET=

# Email API secrets. The Supabase Edge Function queues validated intents only;
# SMTP credentials belong on the Ubuntu worker and must never use a VITE_ prefix.
EMAIL_UNSUBSCRIBE_SECRET=replace-with-at-least-32-random-bytes
EMAIL_RATE_LIMIT_SALT=replace-with-at-least-32-random-bytes
TURNSTILE_SECRET_KEY=
