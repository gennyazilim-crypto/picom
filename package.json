{
  "name": "picom",
  "version": "0.1.0",
  "description": "Picom premium desktop community chat app.",
  "author": "Picom Contributors",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run electron:dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "web:dev": "vite --host 127.0.0.1",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:build && node scripts/electron-dev.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run electron:build && vite build",
    "package": "npm run build && electron-builder --dir",
    "package:win:dir": "npm run build && electron-builder --win --x64 --dir",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:linux:appimage": "npm run build && electron-builder --linux AppImage --x64",
    "package:linux:deb": "npm run build && electron-builder --linux deb --x64",
    "package:linux": "npm run build && electron-builder --linux --x64",
    "package:mac:dmg": "npm run build && electron-builder --mac dmg --x64",
    "package:mac:zip": "npm run build && electron-builder --mac zip --x64",
    "package:mac": "npm run build && electron-builder --mac --x64",
    "package:verify": "node scripts/verify-electron-packaging.mjs",
    "packaging:smoke": "node scripts/verify-electron-packaging.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "env:smoke": "node scripts/env-safety-smoke-test.mjs",
    "qa:output:smoke": "node scripts/qa-output-smoke-test.mjs",
    "react:hooks:smoke": "node scripts/react-hook-order-smoke-test.mjs",
    "logs:smoke": "node scripts/logging-service-smoke-test.mjs",
    "diagnostics:smoke": "node scripts/diagnostics-redaction-smoke-test.mjs",
    "errors:smoke": "node scripts/error-codes-smoke-test.mjs",
    "crash:smoke": "node scripts/crash-diagnostics-smoke-test.mjs",
    "secrets:smoke": "node scripts/secret-exposure-smoke-test.mjs",
    "renderer:native:smoke": "node scripts/renderer-native-api-smoke-test.mjs",
    "branding:smoke": "node scripts/branding-smoke-test.mjs",
    "desktop:smoke": "node scripts/desktop-only-smoke-test.mjs",
    "electron:security:smoke": "node scripts/electron-security-smoke-test.mjs",
    "settings:diagnostics:smoke": "node scripts/settings-diagnostics-smoke-test.mjs",
    "livekit:smoke": "node scripts/livekit-smoke-test.mjs",
    "qa:smoke": "node scripts/qa-smoke-gate.mjs",
    "qa:supabase": "node scripts/supabase-qa-gate.mjs",
    "supabase:types": "supabase gen types typescript --local --schema public > src/services/supabase/database.types.ts",
    "supabase:smoke": "node scripts/supabase-schema-smoke-test.mjs",
    "mock:smoke": "node scripts/mock-mode-smoke-test.mjs",
    "jobs:smoke": "node scripts/job-queue-smoke-test.mjs",
    "invites:cleanup:dry-run": "node scripts/cleanup-expired-invites.mjs",
    "invites:cleanup:smoke": "node scripts/expired-invites-cleanup-smoke-test.mjs",
    "uploads:cleanup:dry-run": "node scripts/cleanup-orphaned-uploads.mjs",
    "uploads:cleanup:smoke": "node scripts/orphaned-uploads-cleanup-smoke-test.mjs",
    "email:smoke": "node scripts/email-service-smoke-test.mjs",
    "auth:password-reset:smoke": "node scripts/password-reset-smoke-test.mjs",
    "auth:email-verification:smoke": "node scripts/email-verification-smoke-test.mjs",
    "supabase:api-regression": "node scripts/supabase-api-mode-regression.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@vitejs/plugin-react": "latest",
    "livekit-client": "^2.20.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.cjs"
}
