{
  "name": "picom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run electron:dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "web:dev": "vite --host 127.0.0.1",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:build && concurrently -k \"npm run renderer:dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run electron:build && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.cjs"
}
