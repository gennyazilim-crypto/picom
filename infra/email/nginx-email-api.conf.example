# Public email intents are terminated by the Supabase email-api Edge Function.
# Expose only the local worker health endpoint to localhost/operations tooling.
location = /internal/email/health {
  allow 127.0.0.1;
  allow ::1;
  deny all;
  proxy_pass http://127.0.0.1:8787/health;
  proxy_set_header Host $host;
  proxy_connect_timeout 2s;
  proxy_read_timeout 3s;
}
