# Copy to a protected host-local file, select versions from `apt-cache madison`,
# and never place credentials in this file.
PICOM_TARGET_OS_ID=ubuntu
PICOM_TARGET_OS_VERSION=24.04
PICOM_TARGET_ARCH=x86_64
PICOM_DOCKER_CE_VERSION=REPLACE_WITH_APPROVED_APT_VERSION
PICOM_DOCKER_CE_CLI_VERSION=REPLACE_WITH_APPROVED_APT_VERSION
PICOM_CONTAINERD_VERSION=REPLACE_WITH_APPROVED_APT_VERSION
PICOM_BUILDX_VERSION=REPLACE_WITH_APPROVED_APT_VERSION
PICOM_COMPOSE_VERSION=REPLACE_WITH_APPROVED_APT_VERSION
PICOM_BACKUP_DESTINATION=/mnt/picom-livekit-backup
