# Picom desktop app environment
# Copy to .env.local for local development. Do not commit real secrets.

VITE_APP_ENV=development
VITE_APP_NAME=Picom
VITE_APP_IDENTIFIER=com.picom.desktop
VITE_DATA_SOURCE=mock

# Supabase renderer-safe values only. Never place service-role keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# LiveKit public URL only. API key/secret must be server-side only.
VITE_LIVEKIT_URL=

# Electron dev server URL used by the Electron main process in development.
VITE_DEV_SERVER_URL=http://127.0.0.1:5173