# Picom desktop app environment
# Copy to .env.local for local development. Do not commit real secrets.

VITE_APP_ENV=development
VITE_RELEASE_CHANNEL=dev
# Optional renderer-safe feature flag overrides. Example: enableDiscovery=false,enableBots=false
# Do not put secrets here; VITE_ values are bundled into the renderer.
VITE_FEATURE_FLAGS=
VITE_APP_NAME=Picom
VITE_APP_VERSION=0.1.0
VITE_APP_IDENTIFIER=com.picom.desktop

# mock keeps the MVP desktop UI fully usable without a backend.
# supabase is reserved for backend integration tasks.
VITE_DATA_SOURCE=mock

# Supabase renderer-safe values only.
# These are safe for the Electron renderer when RLS is enabled.
# Never place service-role keys, database passwords, JWT secrets, or private API keys in Vite env variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# LiveKit public URL only. API key/secret must be server-side only.
VITE_LIVEKIT_URL=

# Optional public status page URL. Do not use private admin dashboards or signed links.
VITE_STATUS_PAGE_URL=

# Optional public remote config endpoint. Leave empty to derive from Supabase Edge Functions in Supabase mode.
VITE_REMOTE_CONFIG_URL=

# Public realtime scaling mode. Use supabase_managed for MVP.
VITE_REALTIME_SCALING_MODE=supabase_managed

# Electron dev server URL used by the Electron main process in development.
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
