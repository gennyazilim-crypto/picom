# Picom desktop app environment
# Copy to .env.local for local development. Do not commit real secrets.

VITE_APP_ENV=development
VITE_RELEASE_CHANNEL=dev
# Staging desktop builds should use VITE_RELEASE_CHANNEL=beta.
# Protected stable builds must set VITE_RELEASE_CHANNEL=stable explicitly.
# Picom never infers stable from a missing environment value.
# Optional renderer-safe feature flag overrides. Example: enableDiscovery=false,enableBots=false
# Do not put secrets here; VITE_ values are bundled into the renderer.
VITE_FEATURE_FLAGS=
VITE_APP_NAME=Picom
VITE_APP_VERSION=1.0.0
VITE_APP_IDENTIFIER=com.picom.desktop

# Picom runtime is Supabase-only. Mock fixtures are not available in the desktop app.
VITE_DATA_SOURCE=supabase

# Supabase renderer-safe values only.
# These are safe for the Electron renderer when RLS is enabled.
# Never place service-role keys, database passwords, JWT secrets, or private API keys in Vite env variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase OAuth provider toggles are renderer-safe availability flags, not secrets.
# Provider client secrets must only be configured in the Supabase dashboard.
VITE_SUPABASE_OAUTH_REDIRECT_URL=picom://auth/callback
VITE_SUPABASE_PASSWORD_RESET_REDIRECT_URL=picom://auth/reset-password
VITE_SUPABASE_EMAIL_VERIFICATION_REDIRECT_URL=picom://auth/verify-email
# Enable only after hosted SMTP, templates, redirect allowlist, cooldown and cross-platform callbacks pass staging.
VITE_REQUIRE_EMAIL_VERIFICATION=false
VITE_SUPABASE_GOOGLE_OAUTH_ENABLED=false
VITE_SUPABASE_APPLE_OAUTH_ENABLED=false
VITE_SUPABASE_STEAM_OAUTH_ENABLED=false
VITE_SUPABASE_EPIC_OAUTH_ENABLED=false

# LiveKit public WebSocket URL only, if the renderer needs a safe display/fallback value.
# LIVEKIT_API_KEY and LIVEKIT_API_SECRET are Edge Function secrets and must never use VITE_ prefixes.
#
# Voice + Screen Share are HIDDEN_FROM_V1 on stable. To unlock them on a dev/beta build
# (no UI/UX change; certified V1 stable stays untouched):
#   1. VITE_RELEASE_CHANNEL must be dev or beta (never stable).
#   2. Set VITE_LIVEKIT_ENABLED=true and point VITE_LIVEKIT_URL at your wss:// host.
#   3. Provision LiveKit and set the Edge secrets LIVEKIT_URL / LIVEKIT_API_KEY / LIVEKIT_API_SECRET.
#   4. Deploy the livekit-token Edge Function to that project (do NOT add it to release-manifest.json).
#   5. On the client-config deployment, set PICOM_ENABLE_VOICE_SCREEN=true to advertise the flags.
VITE_LIVEKIT_ENABLED=true
VITE_LIVEKIT_URL=

# Server-side / Supabase Edge Functions only. Never prefix this with VITE_.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional public status page URL. Do not use private admin dashboards or signed links.
VITE_STATUS_PAGE_URL=

# Optional public remote config endpoint. Leave empty to derive from Supabase Edge Functions in Supabase mode.
VITE_REMOTE_CONFIG_URL=

# Public realtime scaling mode. Use supabase_managed for MVP.
VITE_REALTIME_SCALING_MODE=supabase_managed

# Electron dev server URL used by the Electron main process in development.
VITE_DEV_SERVER_URL=http://127.0.0.1:5173

# Desktop auto-update (Electron main process only; never prefix with VITE_ — the renderer
# must not receive these). The updater is disabled unless PICOM_UPDATE_FEED_URL is set AND
# the app is packaged (or PICOM_UPDATE_ALLOW_DEV=1 for local testing). Policy is
# auto-download + manual install: an update installs only after a user-approved restart.
#   PICOM_UPDATE_FEED_URL  HTTPS base URL of the generic update feed hosting latest.yml + the
#                          signed installer for this channel. Leave empty to keep updates off.
#   PICOM_RELEASE_CHANNEL  latest (stable) uses latest.yml; beta/dev read <channel>.yml.
#   PICOM_UPDATE_ALLOW_DEV Set to 1 only to exercise the updater in an unpackaged dev build.
# The committed build ships electron-builder.yml with `publish: null`; hosting/signing are set
# up per docs/update/real-auto-update-implementation-plan.md before a real feed is configured.
# PICOM_UPDATE_FEED_URL=
# PICOM_RELEASE_CHANNEL=beta
# PICOM_UPDATE_ALLOW_DEV=
