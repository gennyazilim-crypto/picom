# Picom beta desktop app environment
# Copy to .env.local only for beta smoke testing. Do not commit real secrets.

VITE_APP_ENV=beta
VITE_RELEASE_CHANNEL=beta
VITE_APP_NAME=Picom
VITE_APP_IDENTIFIER=com.picom.desktop

# Beta should use Supabase mode for real backend smoke tests.
VITE_DATA_SOURCE=supabase

# Supabase renderer-safe beta values only.
# These are safe for the Electron renderer when RLS is enabled.
# Never place service-role keys, database passwords, JWT secrets, or private API keys here.
VITE_SUPABASE_URL=https://YOUR_BETA_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_BETA_SUPABASE_ANON_KEY

# LiveKit public beta WebSocket URL only.
# API key/secret must stay server-side only.
VITE_LIVEKIT_URL=wss://YOUR_BETA_LIVEKIT_HOST

# Server-side / Supabase Edge Functions only. Never prefix this with VITE_.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY

# Electron dev server URL used by the Electron main process in development.
VITE_DEV_SERVER_URL=http://127.0.0.1:5173
