# Picom production configuration inventory
# This is documentation only. Keep every value empty or obviously placeholder-safe.
# DO NOT copy this entire file to a Vite .env.production file: the lower section is server/CI only.

# Renderer-safe public values. These may be bundled into the Electron renderer.
VITE_APP_ENV=production
VITE_RELEASE_CHANNEL=stable
VITE_APP_NAME=Picom
VITE_APP_VERSION=0.1.1-beta.1
VITE_APP_IDENTIFIER=com.picom.desktop
VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=https://YOUR_PRODUCTION_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PRODUCTION_ANON_KEY
VITE_SUPABASE_OAUTH_REDIRECT_URL=picom://auth/callback
VITE_SUPABASE_GOOGLE_OAUTH_ENABLED=false
VITE_SUPABASE_APPLE_OAUTH_ENABLED=false
VITE_LIVEKIT_ENABLED=false
VITE_LIVEKIT_URL=wss://YOUR_PRODUCTION_LIVEKIT_HOST
VITE_STATUS_PAGE_URL=https://YOUR_PUBLIC_STATUS_PAGE
VITE_REMOTE_CONFIG_URL=
VITE_REALTIME_SCALING_MODE=supabase_managed

# CI/operator placeholders. Store as masked CI secrets, never in renderer env files.
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
# Auth mailer From (Management API / Dashboard SMTP Sender email)
AUTH_SMTP_ADMIN_EMAIL=info@picom.gg
AUTH_SMTP_SENDER_NAME=Picom

# Windows release signing placeholders. Protected CI only; never prefix with VITE_.
# Prefer a managed/hardware-backed signing service. If PFX/PKCS#12 is approved,
# electron-builder can consume these from masked ephemeral CI variables.
CSC_LINK=
CSC_KEY_PASSWORD=

# macOS notarization placeholders. Protected macOS CI only.
# App Store Connect API key authentication is preferred for ephemeral CI.
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
APPLE_TEAM_ID=

# Edge Function/server-only placeholders. Store with `supabase secrets set` or an approved secret manager.
SUPABASE_SERVICE_ROLE_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Ubuntu email worker only. Store these in /etc/picom/email-worker.env with mode 0600.
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@picom.gg
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=info@picom.gg
EMAIL_FROM_NAME=Picom
EMAIL_REPLY_TO=info@picom.gg
EMAIL_WORKER_ID=
EMAIL_WORKER_BATCH_SIZE=10
EMAIL_WORKER_POLL_MS=3000
EMAIL_WORKER_HEALTH_PORT=8787
EMAIL_UNSUBSCRIBE_SECRET=
EMAIL_RATE_LIMIT_SALT=
PICOM_ALLOWED_ORIGINS=
PICOM_V1_VOICE_SCREEN_ENABLED=false
